<%- include("partials/navbar") %>

<link rel="stylesheet" href="/css/scholarships.css">

<!-- Hero -->

<section class="scholarship-hero">

    <div class="container">

        <div class="text-center">

            <span class="hero-badge">
                🎓 Explore Scholarships
